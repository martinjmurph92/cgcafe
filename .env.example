# Database connection string
DATABASE_URL="postgresql://username:password@localhost:5432/database_name"

# Used to encrypt JWT tokens
# Should be a complex and secure string, unguessable
# E.g. openssl rand -hex 32
PAYLOAD_SECRET="YOUR_SECRET_HERE"

# Used to validate preview requests
# Should be a complex and secure string, unguessable
# E.g. openssl rand -hex 32
PREVIEW_SECRET="YOUR_PREVIEW_SECRET_HERE"

# Media is stored locally in the media/ directory (served at /media/static/...)

# Email
# https://payloadcms.com/docs/email/overview#use-smtp
EMAIL_FROM_NAME="Example"
EMAIL_FROM_ADDRESS="noreply@example.com"

# Email: Mailpit (local) / Resend (production)
# Local: uses SMTP → run `pnpm mailpit`, view emails at http://localhost:8025
# Production: uses Resend API → set RESEND_API_KEY below
SMTP_HOST="127.0.0.1"
SMTP_PORT="1025"
# Not required for Mailpit - leave unset or omit
# SMTP_USER=""
# SMTP_PASS=""
# Required in production. Get your key from https://resend.com – replace re_xxxxxxxxx with your real API key
# RESEND_API_KEY="re_xxxxxxxxx"

# Used to configure CORS, format links and more. No trailing slash
NEXT_PUBLIC_SERVER_URL="http://localhost:3000"

UPLOAD_FILE_SIZE_LIMIT=10000000